{
  "model_name": "hybrid_stego_modelC_dual_threshold",
  "img_size": [
    256,
    256
  ],
  "thresholds": {
    "low": 0.45,
    "high": 0.7
  },
  "decision_logic": {
    "0": "clean",
    "1": "stego",
    "-1": "uncertain"
  },
  "class_names": [
    "clean",
    "stego"
  ],
  "preprocessing": {
    "read_mode": "cv2.imread",
    "color_convert": "BGR_TO_RGB",
    "resize": [
      256,
      256
    ],
    "dtype": "float32",
    "divide_by_255": true,
    "normalize": "(img - 0.5) / 0.5"
  }
}